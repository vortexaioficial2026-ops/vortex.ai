# ==============================================
# VORTEX.AI — .gitignore
# ==============================================

# --- CREDENCIAIS — nunca devem ir ao GitHub ---
.env
.env.local
.env.production

# --- DEPENDÊNCIAS — geradas pelo npm install ---
node_modules/

# --- ARQUIVOS TEMPORÁRIOS DE PROCESSAMENTO ---
# Vídeos e áudios gerados durante o uso do sistema
/tmp/
uploads/
*.mp4
*.mp3
*.wav
*.mov
*.webm
*.mkv

# --- LOGS ---
*.log
npm-debug.log*

# --- SISTEMA OPERACIONAL ---
.DS_Store
Thumbs.db

# --- EDITORES DE CÓDIGO ---
.vscode/
.idea/
