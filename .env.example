# ==============================================
# VORTEX.AI — .env.example
# ==============================================
# Copie este arquivo para .env e preencha com
# os valores reais. NUNCA commite o .env.
# ==============================================

# --- SERVIDOR ---
PORT=3000
NODE_ENV=production

# --- OPENROUTER ---
# Gere em: https://openrouter.ai/keys
# Ative Zero Data Retention na criação da chave.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-flash-1.5

# --- UPLOAD ---
# 150MB em bytes
MAX_FILE_SIZE_BYTES=157286400

# --- SEGURANÇA ---
# URL do front-end autorizado a chamar esta API
CORS_ORIGIN=https://vortexai-landing.vercel.app
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# --- DIRETÓRIO TEMPORÁRIO ---
TEMP_DIR=/tmp/vortex
