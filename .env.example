# ==============================================
# VORTEX.AI — .env.example
# Copie este arquivo para .env e preencha
# os valores reais. Nunca commite o .env.
# ==============================================

# ==============================================
# SERVIDOR
# ==============================================

# Porta em que o servidor Express vai escutar.
# O Render sobrescreve isso automaticamente com 10000.
PORT=3000

# Ambiente de execução: development | production
NODE_ENV=production


# ==============================================
# OPENROUTER — API DE IA
# Obtenha sua chave em: https://openrouter.ai/keys
# ==============================================

# Chave de autenticação da API do OpenRouter.
# Formato: sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-SUA_CHAVE_AQUI

# URL base da API do OpenRouter. Não altere.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Modelo do Gemini usado para análise de áudio.
# Opções testadas:
#   google/gemini-flash-1.5      ← recomendado (rápido e barato)
#   google/gemini-pro-1.5        ← mais preciso, mais caro
OPENROUTER_MODEL=google/gemini-flash-1.5


# ==============================================
# UPLOAD E ARMAZENAMENTO
# ==============================================

# Diretório temporário para vídeos e áudios durante
# o processamento. Deve existir no servidor.
# No Render, /tmp é gravável e não persiste entre deploys.
TEMP_DIR=/tmp/vortex

# Tamanho máximo de upload em bytes.
# 157286400 = 150MB
MAX_FILE_SIZE_BYTES=157286400


# ==============================================
# HARDWARE / DEPENDÊNCIAS (OPCIONAL)
# ==============================================

# Caminho do executável do FFmpeg, se necessário especificar manualmente.
# No Render (Linux), ele já é detectado globalmente se instalado via buildpack.
# FFMPEG_PATH=/usr/bin/ffmpeg


# ==============================================
# SEGURANÇA — CORS
# ==============================================

# Origem permitida para chamadas ao backend.
# Em produção: URL do seu front-end hospedado.
# Em desenvolvimento: http://localhost:5500
CORS_ORIGIN=https://seu-frontend.com
